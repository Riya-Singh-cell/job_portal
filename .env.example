# ══════════════════════════════════════════════
#  MERN Job Portal — Environment Variables
# ══════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# The application will work without Cloudinary
# and SMTP credentials (it falls back to local
# storage and console-logged emails).
# ══════════════════════════════════════════════

# ── Server ───────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ──────────────────────────────────
# Local: mongodb://localhost:27017/jobportal
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/jobportal
MONGO_URI=mongodb://localhost:27017/jobportal

# ── JWT ──────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_me
JWT_EXPIRE=7d
COOKIE_EXPIRE=7

# ── Frontend URL (for CORS & email links) ───
FRONTEND_URL=http://localhost:3000

# ── Cloudinary (optional) ───────────────────
# Sign up at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── SMTP / Email (optional) ─────────────────
# For production, use services like SendGrid,
# Mailgun, or AWS SES.
# For development, use https://mailtrap.io
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@jobportal.com
FROM_NAME=JobPortal

# ── Docker (only needed for docker-compose) ─
MONGO_USER=admin
MONGO_PASSWORD=admin123
